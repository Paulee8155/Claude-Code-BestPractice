{
  "permissions": {
    "allow": [
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(git show*)",
      "Bash(find . *)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(grep*)",
      "Bash(echo*)",
      "Bash(mkdir*)",
      "Bash(cp*)",
      "Bash(mv*)",
      "Bash(touch*)",
      "Bash(which*)",
      "Bash(pwd)",
      "Bash(env)",
      "Bash(printenv*)",
      "Bash(rtk*)",
      "Bash(chmod +x*)",
      "Bash(gh api*)",
      "Bash(gh pr*)",
      "Bash(gh issue*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(chmod -R 777*)",
      "Bash(sudo rm*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PWD}/.claude/hooks/block-destructive.sh\""
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PWD}/.claude/hooks/protect-secrets.sh\""
          }
        ]
      }
    ]
  },
  "autoCompactThreshold": 0.8,
  "enableAllProjectMcpServers": true,
  "respectGitignore": true,
  "cleanupPeriodDays": 30,
  "env": {
    "PATH": "/root/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
  }
}
