  "disableStopHook": true,
  "disableSubagentStartHook": true,
  "disableSubagentStopHook": true,
  "disablePreCompactHook": true,
  "disablePostCompactHook": true,
  "disableSessionStartHook": true,
  "disableSessionEndHook": true,
  "disableSetupHook": true,
  "disableTeammateIdleHook": true,
  "disableTaskCreatedHook": true,
  "disableTaskCompletedHook": true,
  "disableConfigChangeHook": true,
  "disableWorktreeCreateHook": true,
  "disableWorktreeRemoveHook": true,
  "disableInstructionsLoadedHook": true,
  "disableElicitationHook": true,
  "disableElicitationResultHook": true,
  "disableStopFailureHook": true,
  "disableCwdChangedHook": true,
