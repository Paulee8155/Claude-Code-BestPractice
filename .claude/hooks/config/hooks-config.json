{
  "_comment": "Toggle individual hooks via disable<EventName>Hook. Override per-machine in hooks-config.local.json (gitignored).",
  "disableLogging": true,
  "disableSound": true,

  "disablePreToolUseHook": false,
  "disablePostToolUseHook": false,
  "disablePostToolUseFailureHook": true,
  "disablePermissionRequestHook": true,
  "disableUserPromptSubmitHook": false,
  "disableNotificationHook": true,
  "disableStopHook": false,
  "disableSubagentStartHook": true,
  "disableSubagentStopHook": true,
  "disablePreCompactHook": true,
  "disablePostCompactHook": true,
  "disableSessionStartHook": false,
  "disableSessionEndHook": true,
  "disableSetupHook": true,
  "disableTeammateIdleHook": true,
  "disableTaskCreatedHook": true,
  "disableTaskCompletedHook": true,
  "disableConfigChangeHook": true,
  "disableWorktreeCreateHook": true,
  "disableWorktreeRemoveHook": true,
  "disableInstructionsLoadedHook": true,
  "disableElicitationHook": true,
  "disableElicitationResultHook": true,
  "disableStopFailureHook": true,
  "disableCwdChangedHook": true,
  "disableFileChangedHook": true,
  "disablePermissionDeniedHook": true,

  "_safety": "PreToolUse runs block-destructive + protect-secrets. PostToolUse runs auto-format (best-effort, silent if formatter missing). Stop prints a verification reminder (gated when no active task). SessionStart injects branch + state context. UserPromptSubmit nudges if PROJECT_RULES.md is still a template.",
  "safety": {
    "blockDestructive": true,
    "protectSecrets": true,
    "autoFormat": true,
    "verificationReminder": true,
    "verificationReminderQuietWhenIdle": true,
    "sessionContextLoad": true,
    "projectRulesNudge": true
  },

  "_log": "When disableLogging is false, hook events are appended to .claude/hooks/log.jsonl",
  "logFile": ".claude/hooks/log.jsonl"
}
